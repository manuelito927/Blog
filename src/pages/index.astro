---
// DATA OPTIMIZATION (Neuro-Copywriting)
const featured = {
  category: "NEURO-HACKING",
  title: "Riprogrammare il Carattere: la scienza dietro i tuoi risultati",
  excerpt: "Non sei vittima dei tuoi geni. Scopri come la neuroplasticità e la filosofia stoica creano una mentalità d'acciaio.",
  time: "7 min",
};

const mainPosts = [
  {
    category: "PSICOLOGIA",
    title: "Perché la tua mente ti mente (e come smettere)",
    excerpt: "Analisi dei bias cognitivi che sabotano la tua felicità ogni giorno.",
    time: "4 min",
  },
  {
    category: "PERFORMANCE",
    title: "La Regola dell'1%: Piccole abitudini, enormi ritorni",
    excerpt: "Come la psicologia dello sport trasforma la mediocrità in eccellenza.",
    time: "6 min",
  }
];

const quotes = ["La tua attenzione è la tua moneta più preziosa.", "Domina il caos interno.", "Disciplina è Libertà."];
---

<html lang="it">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MANUEL // LABORATORY OF THE MIND</title>
    <style>
        :root {
            --bg: #050608;
            --surface: #0f1115;
            --accent: #a3c1ad; /* Sage Green: Scientific & Calm */
            --text: #eef1f4;
            --muted: #8a919b;
            --line: rgba(255,255,255,0.06);
        }

        body {
            background-color: var(--bg);
            color: var(--text);
            font-family: 'Inter', system-ui, sans-serif;
            margin: 0;
            line-height: 1.6;
            overflow-x: hidden;
        }

        /* CORREZIONE 3: Progress Bar */
        #progress {
            position: fixed; top: 0; left: 0; height: 3px;
            background: linear-gradient(90deg, var(--accent), #fff);
            z-index: 1000; width: 0%; transition: width 0.1s;
        }

        .container { max-width: 1100px; margin: 0 auto; padding: 0 20px; }

        /* CORREZIONE 1: Brand Authority */
        nav {
            padding: 2rem 0;
            display: flex; justify-content: space-between; align-items: center;
            border-bottom: 1px solid var(--line);
        }
        .logo { font-weight: 900; letter-spacing: -1px; font-size: 1.2rem; }
        .logo span { color: var(--accent); }

        /* CORREZIONE 2: Hero Transformation */
        .hero { padding: 100px 0; text-align: center; }
        .hero h1 { 
            font-size: clamp(2.5rem, 8vw, 5rem); 
            line-height: 1; margin-bottom: 2rem;
            letter-spacing: -3px; font-weight: 800;
        }
        .hero p { color: var(--muted); max-width: 600px; margin: 0 auto 2.5rem; font-size: 1.2rem; }

        /* CORREZIONE 4: Grid Layout (Bento Style) */
        .bento {
            display: grid;
            grid-template-columns: 1.5fr 1fr;
            gap: 20px;
            margin-bottom: 50px;
        }

        .card {
            background: var(--surface);
            padding: 30px;
            border-radius: 24px;
            border: 1px solid var(--line);
            transition: 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            text-decoration: none; color: inherit;
        }
        .card:hover { transform: translateY(-10px); border-color: var(--accent); }

        .featured { grid-column: span 2; background: linear-gradient(135deg, #0f1115 0%, #161a1f 100%); }
        
        .tag { font-size: 0.7rem; font-weight: 800; color: var(--accent); letter-spacing: 2px; text-transform: uppercase; }
        h2, h3 { margin: 15px 0; letter-spacing: -1px; }

        .quote-slider {
            background: var(--line);
            padding: 20px; text-align: center; border-radius: 50px;
            margin: 40px 0; font-style: italic; font-size: 0.9rem;
        }

        .reveal { opacity: 0; transform: translateY(30px); transition: 1s all ease; }
        .reveal.show { opacity: 1; transform: translateY(0); }
    </style>
</head>
<body>
    <div id="progress"></div>

    <div class="container">
        <nav>
            <div class="logo">MANUEL <span>/</span> BRAIN LAB</div>
            <div style="font-size: 0.7rem; color: var(--muted);">EDIZIONE 2026</div>
        </nav>

        <section class="hero reveal">
            <span class="tag">Oltre la psicologia</span>
            <h1>Costruisci la tua mente dominante.</h1>
            <p>Protocolli pratici di filosofia applicata e neuroscienza della performance per chi non accetta il rumore mentale.</p>
            <a href="#articoli" style="background: var(--accent); color: var(--bg); padding: 15px 30px; border-radius: 12px; font-weight: bold; text-decoration: none;">Inizia l'Allenamento</a>
        </section>

        <div class="quote-slider reveal">
            "{quotes[0]}"
        </div>

        <section class="bento" id="articoli">
            <a href="#" class="card featured reveal">
                <span class="tag">{featured.category}</span>
                <h2 style="font-size: 2.5rem;">{featured.title}</h2>
                <p style="color: var(--muted);">{featured.excerpt}</p>
                <div style="margin-top: 20px; font-size: 0.8rem; font-weight: bold;">LEGGI ORA (7 MIN) →</div>
            </a>

            {mainPosts.map(post => (
                <a href="#" class="card reveal">
                    <span class="tag">{post.category}</span>
                    <h3>{post.title}</h3>
                    <p style="font-size: 0.9rem; color: var(--muted);">{post.excerpt}</p>
                    <div style="margin-top: 20px; font-size: 0.8rem;">{post.time} read →</div>
                </a>
            ))}
        </section>
    </div>

    <script>
        // Progress Bar Script
        window.onscroll = function() {
            let winScroll = document.body.scrollTop || document.documentElement.scrollTop;
            let height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
            let scrolled = (winScroll / height) * 100;
            document.getElementById("progress").style.width = scrolled + "%";
        };

        // Reveal Animation
        const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) entry.target.classList.add("show");
            });
        }, { threshold: 0.1 });

        document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
    </script>
</body>
</html>