---
// DATASET: Rigore e Documentazione
const metadata = {
  title: "Manuel | Analisi Scientifica della Mente e della Performance",
  description: "Archivio di studi e riflessioni basate su evidenze scientifiche in psicologia cognitiva, filosofia del comportamento e scienze dello sport."
};

const categories = [
  { name: "Psicologia Cognitiva", slug: "psicologia" },
  { name: "Filosofia Comportamentale", slug: "filosofia" },
  { name: "Scienze dello Sport", slug: "sport" }
];

const featuredPost = {
  id: 1,
  category: "Neuroscienze",
  title: "Meccanismi neurali della resilienza: oltre il concetto di forza di volontà",
  excerpt: "Un'analisi approfondita su come i circuiti della corteccia prefrontale mediale modulano la risposta allo stress cronico e alla fatica.",
  date: "14 Marzo 2026",
  readingTime: "12 min",
  citations: 8
};

const recentArticles = [
  {
    category: "Psicologia dello Sport",
    title: "L'interferenza contestuale nell'apprendimento motorio",
    excerpt: "Perché la varietà degli stimoli durante l'allenamento produce una ritenzione mnemonica superiore rispetto alla ripetizione costante.",
    time: "8 min",
    level: "Avanzato"
  },
  {
    category: "Filosofia",
    title: "Epitteto e la neuroplasticità: convergenze tra Stoicismo e CBT",
    excerpt: "Come le antiche tecniche di ristrutturazione cognitiva trovano oggi conferma nei processi di rimodellamento sinaptico.",
    time: "10 min",
    level: "Intermedio"
  },
  {
    category: "Psicologia Positiva",
    title: "Il paradosso del benessere: analisi critica del concetto di 'Flow'",
    excerpt: "Oltre Mihály Csíkszentmihályi: cosa dicono le recenti scansioni fMRI sullo stato di immersione totale.",
    time: "7 min",
    level: "Scientifico"
  }
];

const methodology = [
  { title: "Evidenze", desc: "Ogni articolo cita fonti peer-reviewed e studi clinici validati." },
  { title: "Rigore", desc: "Nessuna promessa di 'hackeraggio veloce'. Solo analisi di processi biologici reali." },
  { title: "Prassi", desc: "Trasposizione della teoria in protocolli applicabili basati sulla letteratura scientifica." }
];
---

<html lang="it">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{metadata.title}</title>
    <style>
        :root {
            /* Palette: Deep Research (Blu Notte, Grigio Tecnico, Bianco Carta) */
            --bg: #0a0b0e;
            --surface: #14161c;
            --accent: #6482ad; /* Steel Blue: professionale, freddo, affidabile */
            --text-primary: #e2e8f0;
            --text-secondary: #94a3b8;
            --border: rgba(255, 255, 255, 0.08);
            --font-serif: 'Georgia', serif; /* Per i titoli: trasmette autorità accademica */
            --font-sans: 'Inter', system-ui, sans-serif; /* Per il corpo: massima leggibilità */
        }

        * { box-sizing: border-box; }
        body {
            background-color: var(--bg);
            color: var(--text-primary);
            font-family: var(--font-sans);
            margin: 0;
            line-height: 1.7; /* Ottimale per testi lunghi e complessi */
            -webkit-font-smoothing: antialiased;
        }

        .progress-bar {
            position: fixed; top: 0; left: 0; height: 2px;
            background: var(--accent); z-index: 1000; width: 0%;
        }

        .container { max-width: 1200px; margin: 0 auto; padding: 0 40px; }

        /* Navigation */
        nav {
            padding: 1.5rem 0;
            border-bottom: 1px solid var(--border);
            display: flex; justify-content: space-between; align-items: center;
        }
        .logo { font-weight: 700; letter-spacing: 1px; font-size: 0.9rem; text-transform: uppercase; }
        .nav-links { display: flex; gap: 2rem; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; }
        .nav-links a { text-decoration: none; color: var(--text-secondary); transition: color 0.3s; }
        .nav-links a:hover { color: var(--accent); }

        /* Hero: The Thesis Statement */
        .hero { padding: 120px 0 80px; border-bottom: 1px solid var(--border); }
        .hero-label { color: var(--accent); font-size: 0.8rem; font-weight: 600; text-transform: uppercase; margin-bottom: 1rem; display: block; }
        h1 { 
            font-family: var(--font-serif);
            font-size: clamp(2rem, 5vw, 3.5rem); 
            line-height: 1.1; margin: 0 0 2rem; font-weight: 400;
        }
        .hero-desc { max-width: 700px; color: var(--text-secondary); font-size: 1.1rem; }

        /* Grid Layout */
        .main-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 60px; margin: 60px 0; }

        /* Featured Article */
        .featured-card { text-decoration: none; color: inherit; display: block; margin-bottom: 60px; }
        .featured-card:hover h2 { text-decoration: underline; color: var(--accent); }
        .meta { font-size: 0.75rem; color: var(--text-secondary); margin-bottom: 1rem; display: flex; gap: 15px; }
        .meta span { border-left: 1px solid var(--border); padding-left: 15px; }
        .meta span:first-child { border: none; padding: 0; }
        h2 { font-family: var(--font-serif); font-size: 2.2rem; margin: 0 0 1.5rem; font-weight: 400; }
        .excerpt { color: var(--text-secondary); font-size: 1rem; margin-bottom: 2rem; }

        /* Sidebar: Methods & Context */
        .sidebar-section { margin-bottom: 40px; padding: 30px; background: var(--surface); border-radius: 4px; border: 1px solid var(--border); }
        .sidebar-section h3 { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 2px; margin-top: 0; color: var(--accent); }
        .sidebar-item { margin-bottom: 20px; font-size: 0.9rem; }
        .sidebar-item strong { display: block; color: var(--text-primary); margin-bottom: 5px; }
        .sidebar-item p { margin: 0; color: var(--text-secondary); font-size: 0.85rem; line-height: 1.5; }

        /* Article List */
        .article-list { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; }
        .small-card { text-decoration: none; color: inherit; }
        .small-card h4 { font-family: var(--font-serif); font-size: 1.4rem; margin: 10px 0; font-weight: 400; transition: color 0.3s; }
        .small-card:hover h4 { color: var(--accent); }

        footer { padding: 80px 0 40px; border-top: 1px solid var(--border); color: var(--text-secondary); font-size: 0.8rem; }

        .reveal { opacity: 0; transform: translateY(20px); transition: 0.8s all ease; }
        .reveal.show { opacity: 1; transform: translateY(0); }

        @media (max-width: 900px) {
            .main-grid { grid-template-columns: 1fr; }
            .article-list { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <div class="progress-bar" id="pb"></div>

    <div class="container">
        <nav>
            <div class="logo">Manuel <span>/</span> Archive</div>
            <div class="nav-links">
                <a href="#articles">Indice</a>
                <a href="#method">Metodologia</a>
                <a href="#about">Informazioni</a>
            </div>
        </nav>

        <header class="hero reveal">
            <span class="hero-label">Pubblicazioni e Analisi</span>
            <h1>L'intersezione tra neuroscienze applicate e comportamento umano.</h1>
            <p class="hero-desc">
                Un archivio di articoli di approfondimento tecnico. Nessuna semplificazione eccessiva, solo rigore metodologico per esplorare la mente, la filosofia e la prestazione sportiva.
            </p>
        </header>

        <main class="main-grid">
            <section id="articles">
                <a href="#" class="featured-card reveal">
                    <div class="meta">
                        <span>{featuredPost.category}</span>
                        <span>{featuredPost.date}</span>
                        <span>{featuredPost.readingTime} lettura</span>
                        <span>{featuredPost.citations} Citazioni</span>
                    </div>
                    <h2>{featuredPost.title}</h2>
                    <p class="excerpt">{featuredPost.excerpt}</p>
                    <div style="font-weight: 600; font-size: 0.8rem; color: var(--accent);">LEGGI L'ANALISI COMPLETA →</div>
                </a>

                <div class="article-list">
                    {recentArticles.map(post => (
                        <a href="#" class="small-card reveal">
                            <div class="meta">
                                <span>{post.category}</span>
                                <span>{post.time}</span>
                            </div>
                            <h4>{post.title}</h4>
                            <p class="excerpt" style="font-size: 0.85rem;">{post.excerpt}</p>
                        </a>
                    ))}
                </div>
            </section>

            <aside>
                <div class="sidebar-section reveal" id="method">
                    <h3>Metodologia</h3>
                    {methodology.map(m => (
                        <div class="sidebar-item">
                            <strong>{m.title}</strong>
                            <p>{m.desc}</p>
                        </div>
                    ))}
                </div>

                <div class="sidebar-section reveal">
                    <h3>Livelli di Lettura</h3>
                    <p style="font-size: 0.8rem; color: var(--text-secondary);">
                        Gli articoli sono classificati in base alla densità di riferimenti bibliografici e alla complessità dei termini tecnici utilizzati.
                    </p>
                </div>
            </aside>
        </main>

        <footer>
            <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 20px;">
                <div>© 2026 Manuel Archive. Tutti i diritti riservati. Fonti basate su letteratura peer-reviewed.</div>
                <div style="display: flex; gap: 20px;">
                    <a href="#" style="color: inherit;">RSS Feed</a>
                    <a href="#" style="color: inherit;">Privacy Policy</a>
                </div>
            </div>
        </footer>
    </div>

    <script>
        // Progress Bar dinamica
        window.onscroll = () => {
            const scroll = document.documentElement.scrollTop;
            const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
            document.getElementById("pb").style.width = (scroll / height) * 100 + "%";
        };

        // Reveal al passaggio
        const obs = new IntersectionObserver(entries => {
            entries.forEach(e => { if(e.isIntersecting) e.target.classList.add('show') });
        }, { threshold: 0.1 });
        document.querySelectorAll('.reveal').forEach(r => obs.observe(r));
    </script>
</body>
</html>