---

<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Domina la tua Mente | Blog Manuel</title>
    <meta
      name="description"
      content="Ingegneria del carattere e della mente. Psicologia, filosofia e sport per una vita di massima lucidità."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">

    <style>
      :root {
        /* Palette studiata per ridurre il cortisolo e aumentare il focus */
        --bg: #08090a;
        --surface: #121418;
        --surface-accent: rgba(155, 184, 165, 0.05);
        --text: #f0f2f5;
        --muted: #a0a8b3;
        --accent: #b2cfbb; /* Verde salvia: calma e crescita */
        --accent-vibrant: #769f84;
        --line: rgba(255, 255, 255, 0.08);
        
        /* Tipografia Scientifica */
        --font-main: 'Inter', sans-serif;
        --ls-tight: -0.04em;
        --content-width: 70ch; /* Lunghezza riga ottimale per l'occhio */
      }

      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; font-size: 18px; /* Base 10/10 per la leggibilità */ }

      body {
        margin: 0;
        color: var(--text);
        font-family: var(--font-main);
        background-color: var(--bg);
        line-height: 1.65; /* Rapporto aureo per il respiro visivo */
        -webkit-font-smoothing: antialiased;
      }

      .container {
        width: min(1200px, 92%);
        margin: 0 auto;
      }

      /* Barra di Progresso "Dopaminergica" */
      .progress-container {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 3px;
        background: rgba(255,255,255,0.05);
        z-index: 1000;
      }
      #progressBar {
        height: 100%;
        width: 0%;
        background: linear-gradient(90deg, var(--accent), var(--accent-vibrant));
        box-shadow: 0 0 10px var(--accent);
      }

      /* Navigazione Silenziosa */
      .nav {
        padding: 1.5rem 0;
        border-bottom: 1px solid var(--line);
        backdrop-filter: blur(12px);
        background: rgba(8, 9, 10, 0.8);
        position: sticky;
        top: 0;
        z-index: 900;
      }
      .nav-inner { display: flex; justify-content: space-between; align-items: center; }
      .logo { font-weight: 800; font-size: 1.2rem; letter-spacing: var(--ls-tight); }
      .logo span { color: var(--accent); }

      /* Hero: Il "Gancio" (Pattern Interrupt) */
      .hero {
        padding: 100px 0 60px;
        text-align: center;
      }
      .eyebrow {
        color: var(--accent);
        text-transform: uppercase;
        letter-spacing: 0.3em;
        font-size: 0.7rem;
        font-weight: 600;
        margin-bottom: 1.5rem;
        display: block;
      }
      h1 {
        font-size: clamp(2.5rem, 8vw, 4.5rem);
        line-height: 1.1;
        letter-spacing: -0.06em;
        margin-bottom: 1.5rem;
        font-weight: 800;
      }
      .hero-sub {
        max-width: var(--content-width);
        margin: 0 auto 2.5rem;
        color: var(--muted);
        font-size: 1.1rem;
      }

      .btn {
        padding: 1rem 2rem;
        border-radius: 12px;
        font-weight: 600;
        transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);
        display: inline-block;
        text-decoration: none;
      }
      .btn-primary {
        background: var(--text);
        color: var(--bg);
      }
      .btn-primary:hover { transform: translateY(-3px); box-shadow: 0 10px 30px rgba(255,255,255,0.1); }

      /* Grid System: Cognitive Ease */
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 1.5rem;
        margin-top: 3rem;
      }

      .card {
        background: var(--surface);
        padding: 2rem;
        border-radius: 24px;
        border: 1px solid var(--line);
        transition: all 0.4s ease;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        cursor: pointer;
      }
      .card:hover {
        border-color: var(--accent);
        background: rgba(255,255,255,0.02);
        transform: translateY(-8px);
      }
      .card h3 { margin: 1rem 0; font-size: 1.4rem; line-height: 1.3; letter-spacing: var(--ls-tight); }
      .card p { color: var(--muted); font-size: 0.95rem; margin-bottom: 2rem; }
      .meta { font-size: 0.75rem; color: var(--accent); font-weight: 600; text-transform: uppercase; }

      /* Proof Section */
      .proof-bar {
        background: var(--surface-accent);
        padding: 1.5rem 0;
        margin: 4rem 0;
        border-y: 1px solid var(--line);
      }
      .proof-inner {
        display: flex;
        justify-content: space-around;
        flex-wrap: wrap;
        gap: 2rem;
        font-size: 0.85rem;
        color: var(--muted);
        text-align: center;
      }

      /* Pillastri (Authority) */
      .pillars { padding: 80px 0; }
      .pillar-card { text-align: left; }
      .pillar-card span { font-size: 3rem; font-weight: 800; color: rgba(255,255,255,0.05); display: block; margin-bottom: -1rem; }

      footer {
        padding: 4rem 0;
        border-top: 1px solid var(--line);
        text-align: center;
        color: var(--muted);
        font-size: 0.8rem;
      }

      /* Animazioni per il rilascio di dopamina visiva */
      .reveal { opacity: 0; transform: translateY(30px); transition: all 0.8s ease-out; }
      .reveal.active { opacity: 1; transform: translateY(0); }

      @media (max-width: 768px) {
        h1 { font-size: 2.5rem; }
        .hero { padding: 60px 0; }
      }
    </style>
  </head>

  <body>
    <div class="progress-container"><div id="progressBar"></div></div>

    <nav class="nav">
      <div class="container nav-inner">
        <div class="logo">MANUEL <span>//</span> BRAIN LAB</div>
        <div style="font-size: 0.8rem; font-weight: 600; color: var(--muted);">FILOSOFIA × SCIENZA × SPORT</div>
      </div>
    </nav>

    <main>
      <section class="hero container reveal">
        <span class="eyebrow">Protocolli di Evoluzione Mentale</span>
        <h1>Non leggere solo.<br>Trasforma il tuo <span>Hardware</span>.</h1>
        <p class="hero-sub">
          Dalla psicologia positiva alla neuroscienza dello sport: strumenti scientifici per chi non accetta la mediocrità cognitiva.
        </p>
        <a href="#articoli" class="btn btn-primary">Inizia la tua Trasformazione</a>
      </section>

      <section class="proof-bar">
        <div class="container proof-inner">
          {proof.map(item => <div>• {item}</div>)}
        </div>
      </section>

      <section class="container" id="articoli">
        <div style="text-align: center; margin-bottom: 3rem;">
          <span class="meta">Contenuti ad alto impatto</span>
          <h2 style="font-size: 2.5rem; letter-spacing: -0.04em;">Hackera il tuo comportamento.</h2>
        </div>

        <div class="grid">
          <article class="card reveal" style="grid-column: span 2; background: linear-gradient(145deg, #121418, #1a1d23);">
            <div>
              <span class="meta">{featured.category}</span>
              <h3 style="font-size: 2rem;">{featured.title}</h3>
              <p style="font-size: 1.1rem;">{featured.excerpt}</p>
            </div>
            <div style="display: flex; justify-content: space-between; align-items: center;">
              <span class="btn" style="padding: 0; color: var(--accent);">Accedi al protocollo →</span>
              <span style="font-size: 0.8rem; color: var(--muted);">{featured.time}</span>
            </div>
          </article>

          {mainPosts.map(post => (
            <article class="card reveal">
              <div>
                <span class="meta">{post.category}</span>
                <h3>{post.title}</h3>
                <p>{post.excerpt}</p>
              </div>
              <div style="display: flex; justify-content: space-between; align-items: center;">
                <span style="color: var(--accent); font-weight: 600;">Esplora →</span>
                <span style="font-size: 0.8rem; color: var(--muted);">{post.time} read</span>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="pillars container">
        <div class="grid">
          {pillars.map(pillar => (
            <div class="pillar-card reveal">
              <span>{pillar.n}</span>
              <h3>{pillar.title}</h3>
              <p>{pillar.text}</p>
            </div>
          ))}
        </div>
      </section>
    </main>

    <footer>
      <div class="container">
        <p>© 2026 Manuel Brain Lab. Riprogrammazione Mentale, Filosofia, Sport.</p>
        <p style="margin-top: 1rem; opacity: 0.5;">Ottimizzato per cervelli che cercano la verità.</p>
      </div>
    </footer>

    <script>
      // SCRIPT SCIENTIFICI PER RETENTION

      // 1. Barra di avanzamento (Feedback visuale immediato)
      window.onscroll = function() {
        var winScroll = document.body.scrollTop || document.documentElement.scrollTop;
        var height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
        var scrolled = (winScroll / height) * 100;
        document.getElementById("progressBar").style.width = scrolled + "%";
      };

      // 2. Reveal Scroll (Riduce il carico cognitivo mostrando i pezzi poco a poco)
      const observerOptions = { threshold: 0.15 };
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('active');
          }
        });
      }, observerOptions);

      document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
      
      // 3. Fake Loading per stimolare la curiosità (Opzionale, ma efficace)
      console.log("Neuro-Engine Active: 100%");
    </script>
  </body>
</html>