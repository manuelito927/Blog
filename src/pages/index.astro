---
const metadata = {
  title: "MANUEL ARCHIVE | Neuroscienze e Comportamento",
  description: "Ricerca indipendente su biologia del carattere e modelli mentali per l'alto rendimento."
};

const articles = [
  {
    cat: "NEUROBIOLOGIA",
    title: "La Chimica della Disciplina: Oltre la Forza di Volontà",
    desc: "Analisi dei circuiti dopaminergici e del ruolo della corteccia prefrontale nella gestione dello sforzo.",
    time: "10 min",
    level: "Technical"
  },
  {
    cat: "PSICOLOGIA",
    title: "Bias Cognitivi: L'architettura del tuo auto-inganno",
    desc: "Come il cervello distorce la realtà per risparmiare energia e come resettare i filtri percettivi.",
    time: "8 min",
    level: "Scientific"
  }
];
---

<html lang="it">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
    <title>{metadata.title}</title>
    <style>
        :root {
            --bg: #050608;
            --surface: #0f1115;
            --accent: #7d9bbd; /* Blu Ardesia - Autorità */
            --text-p: #e2e8f0;
            --text-s: #818996;
            --border: rgba(255,255,255,0.06);
            --font-serif: 'Spectral', Georgia, serif;
            --font-sans: 'Inter', system-ui, sans-serif;
        }

        /* RESET & BASE */
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { 
            background: var(--bg); 
            color: var(--text-p); 
            font-family: var(--font-sans); 
            line-height: 1.6;
            overflow-x: hidden;
            opacity: 0; /* Nascondiamo tutto finché non è pronto */
            transition: opacity 0.8s ease;
        }
        body.loaded { opacity: 1; }

        /* PRE-LOADER (Corretto) */
        #loader {
            position: fixed; inset: 0; background: var(--bg);
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            z-index: 9999; transition: opacity 0.6s ease, visibility 0.6s;
        }
        .spinner {
            width: 40px; height: 40px; border: 2px solid var(--border);
            border-top-color: var(--accent); border-radius: 50%;
            animation: spin 1s linear infinite; margin-bottom: 20px;
        }
        @keyframes spin { to { transform: rotate(360deg); } }
        
        /* LAYOUT */
        .container { width: min(1100px, 100% - 40px); margin: 0 auto; }
        
        nav { 
            padding: 30px 0; display: flex; justify-content: space-between; 
            border-bottom: 1px solid var(--border); font-size: 0.75rem; letter-spacing: 2px;
        }
        .logo { font-weight: 800; color: var(--accent); }

        /* HERO - Psicologia dell'Impatto */
        .hero { padding: 80px 0 40px; text-align: left; }
        h1 { 
            font-family: var(--font-serif); font-size: clamp(2.2rem, 8vw, 4rem); 
            line-height: 1.1; margin-bottom: 25px; font-weight: 400;
        }
        .hero p { color: var(--text-s); font-size: 1.2rem; max-width: 650px; border-left: 2px solid var(--accent); padding-left: 20px; }

        /* MAIN CONTENT */
        .main-grid { display: grid; grid-template-columns: 1fr; gap: 40px; margin-top: 60px; }
        @media (min-width: 1024px) { .main-grid { grid-template-columns: 2fr 1fr; } }

        /* CARDS */
        .card { 
            background: var(--surface); padding: 30px; border-radius: 4px; 
            border: 1px solid var(--border); text-decoration: none; color: inherit;
            display: block; transition: 0.4s cubic-bezier(0.2, 1, 0.3, 1);
            margin-bottom: 20px;
        }
        .card:hover { border-color: var(--accent); transform: translateY(-5px); }
        .tag { font-size: 0.65rem; font-weight: 700; color: var(--accent); letter-spacing: 1.5px; margin-bottom: 10px; display: block; }
        .card h2 { font-family: var(--font-serif); font-size: 1.8rem; margin-bottom: 15px; font-weight: 400; }
        .card p { color: var(--text-s); font-size: 0.95rem; }

        /* SIDEBAR */
        .sidebar-box { padding: 25px; background: rgba(255,255,255,0.02); border: 1px solid var(--border); margin-bottom: 20px; }
        .sidebar-box h4 { font-size: 0.7rem; letter-spacing: 1px; color: var(--accent); text-transform: uppercase; margin-bottom: 15px; }
        .sidebar-box p { font-size: 0.85rem; color: var(--text-s); }

        /* PROGRESS BAR */
        #progress { position: fixed; top: 0; left: 0; height: 3px; background: var(--accent); z-index: 10000; width: 0%; }

    </style>
    <link href="https://fonts.googleapis.com/css2?family=Spectral:wght@400;700&family=Inter:wght@400;700&display=swap" rel="stylesheet">
</head>
<body>

    <div id="progress"></div>

    <div id="loader">
        <div class="spinner"></div>
        <div id="loader-text" style="font-size: 0.7rem; letter-spacing: 2px; color: var(--text-s);">CALIBRAZIONE SINAPTICA...</div>
    </div>

    <div class="container">
        <nav>
            <div class="logo">MANUEL // ARCHIVE</div>
            <div style="color: var(--text-s);">VOL. 2026</div>
        </nav>

        <header class="hero">
            <h1>Ingegneria della mente e del carattere.</h1>
            <p>Protocolli tecnici basati su evidenze scientifiche. Nessuna motivazione, solo analisi dei processi bio-comportamentali.</p>
        </header>

        <main class="main-grid">
            <section>
                {articles.map(post => (
                    <a href="#" class="card">
                        <span class="tag">{post.cat} • {post.time} • {post.level}</span>
                        <h2>{post.title}</h2>
                        <p>{post.desc}</p>
                    </a>
                ))}
            </section>

            <aside>
                <div class="sidebar-box">
                    <h4>Metodologia</h4>
                    <p>Ogni paper citato è verificato tramite database peer-reviewed (PubMed/Nature). L'obiettivo è la precisione del dato, non la velocità di lettura.</p>
                </div>
                <div class="sidebar-box" style="border-left: 2px solid var(--accent);">
                    <h4>Prossimo Rilascio</h4>
                    <p>Analisi della plasticità sinaptica indotta dal sonno profondo. [In Revisione]</p>
                </div>
            </aside>
        </main>
    </div>

    <script>
        // 1. GESTIONE CARICAMENTO (Per evitare il blocco del video/immagine che hai mandato)
        window.addEventListener('load', () => {
            const loader = document.getElementById('loader');
            // Diamo un senso di "calibrazione reale" con un piccolo delay
            setTimeout(() => {
                loader.style.opacity = '0';
                loader.style.visibility = 'hidden';
                document.body.classList.add('loaded');
            }, 1500); 
        });

        // 2. BARRA DI PROGRESSO (Piacere visivo allo scrolling)
        window.onscroll = () => {
            const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
            const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
            const scrolled = (winScroll / height) * 100;
            document.getElementById("progress").style.width = scrolled + "%";
        };

        // Fallback: se il loader non sparisce dopo 4 secondi, forzalo (Safety first)
        setTimeout(() => {
            document.getElementById('loader').style.display = 'none';
            document.body.classList.add('loaded');
        }, 4000);
    </script>
</body>
</html>