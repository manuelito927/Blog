<!DOCTYPE html>
<html lang="it" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ARCHETYPE | Neuro-Engineering & Positive Philosophy</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Montserrat:wght@200;400;900&display=swap" rel="stylesheet">

    <style>
        :root {
            --obsidian: #020202;
            --gold-leaf: #af944d;
            --neural-gray: #1a1a1a;
            --fluid-type: clamp(1rem, 2vw, 1.5rem);
        }

        body {
            background-color: var(--obsidian);
            color: #ffffff;
            font-family: 'Montserrat', sans-serif;
            cursor: crosshair; /* Neuro-attentional trigger: cambia la percezione dell'interazione */
            overflow-x: hidden;
        }

        .serif-display { font-family: 'Cinzel', serif; }

        /* Effetto di Depth Perception (Psicologia della Gestalt) */
        .layer-blur {
            backdrop-filter: blur(20px);
            background: rgba(2, 2, 2, 0.8);
        }

        /* Scarsità Visiva: Solo un elemento alla volta domina */
        .focus-section {
            min-height: 100vh;
            display: flex;
            align-items: center;
            opacity: 0;
            transform: translateY(50px);
        }

        /* Custom Scrollbar per non interrompere il flow */
        ::-webkit-scrollbar { width: 4px; }
        ::-webkit-scrollbar-track { background: var(--obsidian); }
        ::-webkit-scrollbar-thumb { background: var(--gold-leaf); }

        /* Animazione Carico Cognitivo (Dopamine Loop) */
        #loader {
            position: fixed;
            inset: 0;
            z-index: 999;
            background: var(--obsidian);
            display: flex;
            justify-content: center;
            align-items: center;
            flex-direction: column;
        }

        .neuro-pulse {
            width: 100px;
            height: 100px;
            border: 2px solid var(--gold-leaf);
            border-radius: 50%;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0% { transform: scale(0.9); opacity: 1; }
            100% { transform: scale(1.5); opacity: 0; }
        }
    </style>
</head>
<body>

    <div id="loader">
        <div class="neuro-pulse"></div>
        <p class="mt-8 text-[10px] tracking-[0.5em] text-gray-500 uppercase italic">Calibrazione Sinaptica in corso...</p>
    </div>

    <nav class="fixed top-0 w-full z-50 p-8 flex justify-between items-center mix-blend-difference">
        <div class="text-xl font-bold tracking-[0.3em] serif-display">ARCHETYPE <span class="text-[8px] align-top">©</span></div>
        <div class="flex gap-10 text-[9px] uppercase tracking-widest opacity-60 hover:opacity-100 transition">
            <a href="#lab" class="hover:text-[#af944d]">Protocolli</a>
            <a href="#logic" class="hover:text-[#af944d]">Logica</a>
            <a href="#join" class="border border-white/20 px-4 py-2 rounded-full">Membership</a>
        </div>
    </nav>

    <section class="relative h-screen flex flex-col justify-center px-10 md:px-32 overflow-hidden">
        <div class="absolute right-0 top-0 w-1/2 h-full opacity-20 pointer-events-none">
            <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
                <path fill="#af944d" d="M44.7,-76.4C58.1,-69.2,69.2,-58.1,76.4,-44.7C83.7,-31.3,87.1,-15.7,85.8,-0.7C84.6,14.2,78.7,28.5,70.1,41.1C61.5,53.7,50.2,64.7,36.8,71.5C23.4,78.3,8,80.9,-6.9,79.7C-21.8,78.5,-36.2,73.5,-48.9,65.1C-61.6,56.7,-72.6,44.9,-78.7,31.2C-84.8,17.5,-86.1,1.9,-83.4,-12.9C-80.7,-27.7,-74,-41.7,-64,-53.4C-54,-65.1,-40.7,-74.5,-26.6,-78.9C-12.5,-83.3,2.4,-82.7,18.1,-80.1C33.8,-77.5,44.7,-76.4,44.7,-76.4Z" transform="translate(100 100)" />
            </svg>
        </div>

        <div class="z-10">
            <h2 class="text-[#af944d] text-xs font-bold uppercase tracking-[0.8em] mb-6">Evidence-Based Excellence</h2>
            <h1 class="text-6xl md:text-8xl serif-display leading-none mb-10">
                L'Ingegneria <br> <span class="italic text-gray-500">del Domani</span> <br> Inizia Oggi.
            </h1>
            <p class="max-w-xl text-gray-400 text-sm leading-loose mb-12 border-l-2 border-[#af944d] pl-6">
                Applichiamo il 100% degli studi sulla <strong>Plasticità Neuronale</strong> e sulla <strong>Teoria dei Nudge</strong> per ottimizzare la tua traiettoria biologica. La filosofia non è più astrazione: è un protocollo biochimico.
            </p>
            <button class="bg-[#af944d] text-black px-12 py-5 text-[10px] font-black uppercase tracking-[0.3em] hover:bg-white transition-all transform hover:scale-105">
                Inizia l'Audit Biometrico
            </button>
        </div>
    </section>

    <section id="lab" class="focus-section py-20 px-10 md:px-32 bg-[#050505]">
        <div class="grid md:grid-cols-2 gap-20">
            <div class="space-y-12">
                <h3 class="text-4xl serif-display">Dati, non dogmi.</h3>
                <div class="space-y-8">
                    <div class="group">
                        <span class="text-[10px] text-[#af944d] font-bold uppercase tracking-widest">01 / Biologia della Resilienza</span>
                        <p class="text-gray-500 mt-2 text-sm leading-relaxed">Come il nervo vago influenza il tuo processo decisionale economico (Porges, 2011). Analisi dei biomarcatori dello stress.</p>
                    </div>
                    <div class="group">
                        <span class="text-[10px] text-[#af944d] font-bold uppercase tracking-widest">02 / Psicologia Positiva Applicata</span>
                        <p class="text-gray-500 mt-2 text-sm leading-relaxed">Framework PERMA-V per la massimizzazione del capitale umano in contesti di alta pressione.</p>
                    </div>
                </div>
            </div>
            <div class="relative flex items-center justify-center">
                <div class="w-full h-[400px] border border-white/10 rounded-2xl flex items-center justify-center p-10 overflow-hidden group">
                    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-[#af944d]/20 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition duration-700"></div>
                    <p class="text-center italic text-gray-400 serif-display text-xl">"La mente è l'unico limite della biologia."</p>
                </div>
            </div>
        </div>
    </section>

    <section id="logic" class="py-32 bg-white text-black text-center">
        <div class="max-w-2xl mx-auto px-6">
            <h2 class="text-sm font-black uppercase tracking-[0.5em] mb-12">Assessment Cognitivo</h2>
            <div id="quiz-box" class="p-10 border-2 border-black/5 rounded-3xl transition-all duration-500">
                <p class="text-2xl serif-display mb-10">Qual è il tuo livello attuale di entropia mentale?</p>
                <div class="flex flex-col gap-4">
                    <button onclick="nextStep()" class="border border-black py-4 hover:bg-black hover:text-white transition uppercase text-[10px] font-bold tracking-widest">Calcola Baseline</button>
                    <span class="text-[8px] text-gray-400 mt-4 uppercase tracking-widest italic">Tempo stimato: 45 secondi. Validità scientifica: 98.4%</span>
                </div>
            </div>
        </div>
    </section>

    <footer id="join" class="py-32 px-10 border-t border-white/5">
        <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-end gap-10">
            <div class="max-w-xl">
                <h4 class="text-5xl serif-display mb-8 italic">Entra nel Cerchio.</h4>
                <p class="text-gray-500 text-sm leading-relaxed">Non inviamo newsletter. Distribuiamo <strong>Protocolli di Eccellenza</strong>. Una volta al mese, direttamente nella tua corteccia prefrontale (via email).</p>
                <div class="mt-10 flex gap-4">
                    <input type="email" placeholder="Accesso ID Email" class="bg-transparent border-b border-white/20 py-4 w-full focus:outline-none focus:border-[#af944d] text-sm">
                    <button class="bg-white text-black px-10 font-bold uppercase text-[10px] tracking-tighter">Sincronizza</button>
                </div>
            </div>
            <div class="text-[10px] text-gray-700 tracking-[0.4em] uppercase font-bold text-right">
                Neuro-Marketing <br> Behavioral Economics <br> Cognitive Design <br> 2026 Archive
            </div>
        </div>
    </footer>

    <script>
        // Registrazione Plugin GSAP
        gsap.registerPlugin(ScrollTrigger);

        // LOADER Logic (Dopamine Release Delay)
        window.addEventListener('load', () => {
            setTimeout(() => {
                gsap.to("#loader", { 
                    opacity: 0, 
                    duration: 1.5, 
                    ease: "power4.inOut",
                    onComplete: () => {
                        document.getElementById('loader').style.display = 'none';
                        initAnimations();
                    }
                });
            }, 2000); // Ritardo calcolato per creare aspettativa
        });

        function initAnimations() {
            // Animazione Entrata Hero
            gsap.from("h1", { opacity: 0, x: -100, duration: 1.5, ease: "power4.out" });
            gsap.from("p", { opacity: 0, y: 50, duration: 1.5, delay: 0.5, ease: "power4.out" });

            // Reveal Sections on Scroll (Psicologia della scoperta)
            gsap.utils.toArray('.focus-section').forEach(section => {
                gsap.to(section, {
                    scrollTrigger: {
                        trigger: section,
                        start: "top 80%",
                    },
                    opacity: 1,
                    y: 0,
                    duration: 1.2,
                    ease: "power2.out"
                });
            });
        }

        // QUIZ Logic (Sunk Cost Fallacy)
        function nextStep() {
            const box = document.getElementById('quiz-box');
            box.style.opacity = '0';
            setTimeout(() => {
                box.innerHTML = `
                    <h3 class="text-xl font-bold italic mb-6">Analisi Neuro-Trasmettitori in corso...</h3>
                    <div class="w-full bg-gray-100 h-1 mb-8">
                        <div id="bar" class="bg-[#af944d] h-1 w-0 transition-all duration-[3000ms]"></div>
                    </div>
                    <p class="text-sm text-gray-500 uppercase tracking-widest">Stiamo incrociando i tuoi dati con il database di Kahneman...</p>
                `;
                box.style.opacity = '1';
                setTimeout(() => {
                    document.getElementById('bar').style.width = '100%';
                    setTimeout(() => {
                        box.innerHTML = `
                            <h3 class="text-3xl serif-display mb-4">Profilo: "Ottimizzatore Latente"</h3>
                            <p class="mb-8 text-gray-600">Il tuo cervello mostra un'alta resistenza al bias di conferma, ma soffre di fatica decisionale cronica.</p>
                            <button onclick="location.href='#join'" class="bg-black text-white px-8 py-3 text-[10px] font-bold uppercase tracking-widest">Scarica il tuo Report (PDF)</button>
                        `;
                    }, 3200);
                }, 100);
            }, 500);
        }

        // BIOMETRIC HOVER (Propriocezione Digitale)
        document.addEventListener('mousemove', (e) => {
            const moveX = (e.clientX - window.innerWidth / 2) * 0.01;
            const moveY = (e.clientY - window.innerHeight / 2) * 0.01;
            gsap.to(".serif-display", { x: moveX, y: moveY, duration: 1 });
        });
    </script>
</body>
</html>