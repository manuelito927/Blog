---
const featured = {
  category: "Featured",
  title: "Come costruire un blog che trattiene attenzione, fiducia e click",
  excerpt:
    "Una struttura editoriale che unisce design premium, psicologia dell’attenzione e scrittura scansionabile per aumentare apertura e tempo di lettura.",
  time: "8 min read",
};

const posts = [
  {
    category: "Psicologia",
    title: "Perché gli utenti decidono in pochi istanti se restare o uscire",
    excerpt:
      "Prima impressione, chiarezza e carico cognitivo: i fattori che fanno restare le persone sulla pagina.",
    time: "4 min read",
  },
  {
    category: "Writing",
    title: "Titoli che fermano lo sguardo senza sembrare clickbait",
    excerpt:
      "Come creare headline più forti, concrete e credibili, senza promesse vuote.",
    time: "5 min read",
  },
  {
    category: "Design",
    title: "Il minimalismo che sembra davvero premium",
    excerpt:
      "Spazio, ritmo visivo, contrasto e ordine: cosa rende un sito più autorevole agli occhi del lettore.",
    time: "6 min read",
  },
  {
    category: "Marketing",
    title: "Le leve che aumentano il click sui contenuti",
    excerpt:
      "Gerarchia, featured content, curiosità e call to action posizionate nel punto giusto.",
    time: "5 min read",
  },
  {
    category: "SEO",
    title: "Come avere pagine veloci e più facili da leggere",
    excerpt:
      "Performance percepita, struttura del contenuto e dettagli che aiutano sia utenti sia motori di ricerca.",
    time: "6 min read",
  },
  {
    category: "Brand",
    title: "Cosa rende un blog memorabile oltre ai contenuti",
    excerpt:
      "Voce, coerenza visiva e sensazione di qualità: i dettagli che fanno ricordare il progetto.",
    time: "4 min read",
  },
];

const principles = [
  {
    n: "01",
    title: "Messaggio chiaro subito",
    text: "Il lettore deve capire in pochi secondi cosa trova qui e perché vale il suo tempo.",
  },
  {
    n: "02",
    title: "Scansione facile",
    text: "Blocchi, sottogerarchie e ritmo visivo aiutano chi non legge tutto parola per parola.",
  },
  {
    n: "03",
    title: "Curiosità ordinata",
    text: "Stimolare apertura e click senza sembrare aggressivi o costruiti male.",
  },
];
---

<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Blog Manuel</title>
    <meta
      name="description"
      content="Blog scuro professionale con struttura editoriale premium, progettata per migliorare attenzione, lettura e click."
    />

    <style>
      :root {
        --bg: #050505;
        --bg-2: #0a0a0d;
        --panel: rgba(255, 255, 255, 0.04);
        --panel-2: rgba(255, 255, 255, 0.06);
        --line: rgba(255, 255, 255, 0.08);
        --line-strong: rgba(255, 255, 255, 0.16);
        --text: #f7f7f7;
        --muted: rgba(255, 255, 255, 0.64);
        --muted-2: rgba(255, 255, 255, 0.44);
        --shadow: 0 26px 80px rgba(0, 0, 0, 0.38);
        --radius-xl: 34px;
        --radius-lg: 26px;
        --radius-md: 18px;
        --content-max: 72ch;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        color: var(--text);
        font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Segoe UI", sans-serif;
        background:
          radial-gradient(circle at top, rgba(255,255,255,0.075), transparent 28%),
          linear-gradient(180deg, #050505 0%, #09090b 42%, #050505 100%);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .container {
        width: min(1180px, calc(100% - 24px));
        margin: 0 auto;
      }

      .progress {
        position: fixed;
        top: 0;
        left: 0;
        height: 2px;
        width: 0%;
        z-index: 200;
        background: linear-gradient(90deg, #ffffff, rgba(255,255,255,0.55));
        box-shadow: 0 0 14px rgba(255,255,255,0.28);
      }

      .nav {
        position: sticky;
        top: 0;
        z-index: 150;
        backdrop-filter: blur(16px);
        background: rgba(5, 5, 5, 0.72);
        border-bottom: 1px solid var(--line);
      }

      .nav-inner {
        min-height: 76px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 18px;
      }

      .brand {
        display: flex;
        flex-direction: column;
      }

      .brand small {
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.28em;
        color: var(--muted-2);
      }

      .brand strong {
        margin-top: 5px;
        font-size: 20px;
        letter-spacing: -0.04em;
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 20px;
        color: var(--muted);
        font-size: 14px;
      }

      .nav-links a {
        transition: color 0.25s ease, transform 0.25s ease;
      }

      .nav-links a:hover {
        color: white;
        transform: translateY(-1px);
      }

      .nav-cta {
        padding: 11px 15px;
        border-radius: 14px;
        background: rgba(255,255,255,0.04);
        border: 1px solid var(--line);
      }

      .hero {
        padding: 84px 0 36px;
      }

      .hero-grid {
        display: grid;
        grid-template-columns: 1.15fr 0.85fr;
        gap: 22px;
        align-items: stretch;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 10px 14px;
        border-radius: 999px;
        border: 1px solid var(--line);
        background: rgba(255,255,255,0.03);
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.22em;
        font-size: 11px;
      }

      .eyebrow-dot {
        width: 8px;
        height: 8px;
        border-radius: 999px;
        background: white;
        opacity: 0.95;
      }

      h1 {
        margin: 20px 0 0;
        font-size: clamp(42px, 7vw, 82px);
        line-height: 0.94;
        letter-spacing: -0.06em;
        max-width: 13ch;
      }

      .hero-sub {
        margin-top: 22px;
        max-width: var(--content-max);
        color: var(--muted);
        font-size: 18px;
        line-height: 1.82;
      }

      .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        margin-top: 30px;
      }

      .btn-primary,
      .btn-secondary {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 15px 20px;
        border-radius: 16px;
        border: 1px solid var(--line);
        transition: transform 0.28s ease, border-color 0.28s ease, background 0.28s ease;
        font-size: 14px;
      }

      .btn-primary {
        background: white;
        color: black;
        font-weight: 700;
      }

      .btn-secondary {
        background: rgba(255,255,255,0.03);
        color: white;
      }

      .btn-primary:hover,
      .btn-secondary:hover {
        transform: translateY(-2px);
      }

      .hero-metrics {
        margin-top: 28px;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
      }

      .metric {
        padding: 16px;
        border-radius: 20px;
        border: 1px solid var(--line);
        background: rgba(255,255,255,0.03);
      }

      .metric strong {
        display: block;
        font-size: 16px;
        letter-spacing: -0.03em;
      }

      .metric span {
        display: block;
        margin-top: 6px;
        color: var(--muted);
        line-height: 1.55;
        font-size: 13px;
      }

      .glass {
        position: relative;
        border-radius: var(--radius-xl);
        border: 1px solid var(--line);
        background:
          linear-gradient(180deg, rgba(255,255,255,0.06), rgba(255,255,255,0.025));
        box-shadow: var(--shadow);
      }

      .hero-side {
        padding: 20px;
      }

      .panel-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        color: var(--muted);
        font-size: 13px;
        margin-bottom: 16px;
      }

      .featured-card {
        padding: 24px;
        border-radius: 26px;
        border: 1px solid var(--line);
        background: rgba(0,0,0,0.24);
      }

      .featured-label,
      .meta-line {
        color: var(--muted-2);
        text-transform: uppercase;
        letter-spacing: 0.2em;
        font-size: 11px;
      }

      .featured-card h2 {
        margin: 14px 0 10px;
        font-size: 30px;
        line-height: 1.08;
        letter-spacing: -0.05em;
      }

      .featured-card p {
        margin: 0;
        max-width: 36ch;
        color: var(--muted);
        line-height: 1.82;
        font-size: 15px;
      }

      .featured-meta {
        margin-top: 16px;
        display: flex;
        justify-content: space-between;
        gap: 12px;
        color: var(--muted-2);
        font-size: 13px;
      }

      .section {
        padding: 54px 0 88px;
      }

      .section-head {
        display: flex;
        justify-content: space-between;
        align-items: end;
        gap: 20px;
        margin-bottom: 26px;
      }

      .section-head .left small {
        color: var(--muted-2);
        text-transform: uppercase;
        letter-spacing: 0.24em;
        font-size: 11px;
      }

      .section-head .left h2 {
        margin: 12px 0 0;
        font-size: clamp(30px, 4vw, 48px);
        line-height: 1;
        letter-spacing: -0.05em;
      }

      .section-head .right {
        max-width: 34rem;
        color: var(--muted);
        line-height: 1.82;
      }

      .featured-band {
        display: grid;
        grid-template-columns: 1.14fr 0.86fr;
        gap: 18px;
        margin-bottom: 18px;
      }

      .featured-main,
      .featured-secondary {
        padding: 26px;
      }

      .featured-main h3,
      .featured-secondary h3 {
        margin: 14px 0 10px;
        letter-spacing: -0.04em;
      }

      .featured-main h3 {
        font-size: 34px;
        line-height: 1.02;
      }

      .featured-secondary h3 {
        font-size: 24px;
        line-height: 1.08;
      }

      .featured-main p,
      .featured-secondary p {
        margin: 0;
        max-width: var(--content-max);
        color: var(--muted);
        line-height: 1.84;
      }

      .inline-cta {
        margin-top: 18px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: white;
        font-size: 14px;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 18px;
      }

      .card {
        position: relative;
        overflow: hidden;
        padding: 24px;
        border-radius: 28px;
        border: 1px solid var(--line);
        background:
          linear-gradient(180deg, rgba(255,255,255,0.05), rgba(255,255,255,0.025));
        transition: transform 0.34s ease, border-color 0.34s ease, background 0.34s ease;
      }

      .card:hover {
        transform: translateY(-7px);
        border-color: var(--line-strong);
        background:
          linear-gradient(180deg, rgba(255,255,255,0.07), rgba(255,255,255,0.03));
      }

      .card::before {
        content: "";
        position: absolute;
        top: -42px;
        right: -42px;
        width: 124px;
        height: 124px;
        border-radius: 999px;
        background: rgba(255,255,255,0.04);
        filter: blur(8px);
      }

      .card h3 {
        margin: 14px 0 12px;
        font-size: 24px;
        line-height: 1.12;
        letter-spacing: -0.04em;
      }

      .card p {
        margin: 0;
        color: var(--muted);
        line-height: 1.78;
        max-width: 34ch;
        font-size: 15px;
      }

      .card-bottom {
        margin-top: 18px;
        display: flex;
        justify-content: space-between;
        gap: 12px;
        color: var(--muted-2);
        font-size: 13px;
      }

      .principles {
        padding: 10px 0 90px;
      }

      .principles-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 18px;
      }

      .principle {
        padding: 22px;
        border-radius: 24px;
        border: 1px solid var(--line);
        background: rgba(255,255,255,0.03);
      }

      .principle strong {
        display: block;
        font-size: 34px;
        letter-spacing: -0.06em;
      }

      .principle h3 {
        margin: 12px 0 8px;
        font-size: 20px;
        letter-spacing: -0.03em;
      }

      .principle p {
        margin: 0;
        color: var(--muted);
        line-height: 1.75;
      }

      .about {
        padding: 74px 0 92px;
        border-top: 1px solid var(--line);
      }

      .about-grid {
        display: grid;
        grid-template-columns: 0.92fr 1.08fr;
        gap: 22px;
      }

      .about h2 {
        margin: 12px 0 0;
        font-size: clamp(30px, 4vw, 46px);
        line-height: 1;
        letter-spacing: -0.05em;
      }

      .about p {
        margin: 0;
        max-width: var(--content-max);
        color: var(--muted);
        line-height: 1.92;
        font-size: 16px;
      }

      .footer {
        border-top: 1px solid var(--line);
        color: var(--muted-2);
        padding: 28px 0 42px;
        font-size: 14px;
      }

      .reveal {
        opacity: 0;
        transform: translateY(34px) scale(0.985);
        transition:
          opacity 0.9s ease,
          transform 0.9s ease;
        will-change: transform, opacity;
      }

      .reveal.show {
        opacity: 1;
        transform: translateY(0) scale(1);
      }

      .delay-1 { transition-delay: 0.08s; }
      .delay-2 { transition-delay: 0.16s; }
      .delay-3 { transition-delay: 0.24s; }
      .delay-4 { transition-delay: 0.32s; }

      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }

        .reveal,
        .reveal.show,
        .btn-primary,
        .btn-secondary,
        .card,
        .nav-links a {
          transition: none !important;
          transform: none !important;
          opacity: 1 !important;
        }
      }

      @media (max-width: 980px) {
        .hero-grid,
        .featured-band,
        .about-grid,
        .grid,
        .principles-grid,
        .hero-metrics {
          grid-template-columns: 1fr;
        }

        .section-head {
          display: grid;
          align-items: start;
        }

        .nav-links {
          display: none;
        }

        .hero {
          padding-top: 58px;
        }
      }

      @media (max-width: 640px) {
        .container {
          width: min(100% - 16px, 1180px);
        }

        h1 {
          line-height: 1;
        }

        .hero-sub {
          font-size: 16px;
        }

        .glass,
        .card,
        .featured-main,
        .featured-secondary,
        .principle,
        .metric {
          border-radius: 24px;
        }
      }
    </style>
  </head>

  <body>
    <div class="progress" id="progressBar"></div>

    <header class="nav">
      <div class="container nav-inner">
        <div class="brand">
          <small>Blog professionale</small>
          <strong>Blog Manuel</strong>
        </div>

        <nav class="nav-links">
          <a href="#home">Home</a>
          <a href="#articoli">Articoli</a>
          <a href="#principi">Principi</a>
          <a href="#about">About</a>
          <a href="#articoli" class="nav-cta">Esplora</a>
        </nav>
      </div>
    </header>

    <main>
      <section class="hero container" id="home">
        <div class="hero-grid">
          <div class="reveal">
            <div class="eyebrow">
              <span class="eyebrow-dot"></span>
              contenuti costruiti per fermare lo sguardo
            </div>

            <h1>Idee, strategia e articoli che invitano davvero alla lettura.</h1>

            <div class="hero-sub">
              Un blog scuro, autorevole e ordinato, progettato per rendere tutto più chiaro:
              cosa leggi, perché vale il tuo tempo e quale contenuto aprire per primo.
            </div>

            <div class="hero-actions">
              <a class="btn-primary" href="#articoli">
                Guarda i blog
                <span>→</span>
              </a>

              <a class="btn-secondary" href="#principi">
                Perché funziona
              </a>
            </div>

            <div class="hero-metrics">
              <div class="metric reveal delay-1">
                <strong>Gerarchia forte</strong>
                <span>Prima un contenuto chiave, poi blocchi facili da scansionare.</span>
              </div>
              <div class="metric reveal delay-2">
                <strong>Copy più fluido</strong>
                <span>Testo breve, front-loaded e meno fatica cognitiva.</span>
              </div>
              <div class="metric reveal delay-3">
                <strong>Sensazione premium</strong>
                <span>Spazio, contrasto e ordine aumentano la fiducia percepita.</span>
              </div>
            </div>
          </div>

          <aside class="hero-side glass reveal delay-1">
            <div class="panel-top">
              <span>Contenuto in evidenza</span>
              <span>{featured.time}</span>
            </div>

            <div class="featured-card">
              <div class="featured-label">{featured.category}</div>
              <h2>{featured.title}</h2>
              <p>{featured.excerpt}</p>

              <div class="featured-meta">
                <span>Più chiarezza, più click</span>
                <span>Apri presto</span>
              </div>
            </div>
          </aside>
        </div>
      </section>

      <section class="section container" id="articoli">
        <div class="section-head reveal">
          <div class="left">
            <small>Sezione articoli</small>
            <h2>Una home progettata per guidare l’attenzione.</h2>
          </div>

          <div class="right">
            Invece di presentare tutto allo stesso livello, questa struttura crea priorità visiva:
            prima un focus, poi una seconda porta d’ingresso, poi una griglia rapida da esplorare.
          </div>
        </div>

        <div class="featured-band">
          <article class="featured-main glass reveal">
            <div class="meta-line">{featured.category} · {featured.time}</div>
            <h3>{featured.title}</h3>
            <p>{featured.excerpt}</p>

            <div class="inline-cta">
              <span>Leggi questo articolo</span>
              <span>→</span>
            </div>
          </article>

          <article class="featured-secondary glass reveal delay-1">
            <div class="meta-line">Focus · 3 min read</div>
            <h3>Perché una pagina ordinata viene capita più in fretta.</h3>
            <p>
              Quando l’occhio capisce subito dove guardare, il lettore fa meno sforzo.
              Meno sforzo significa più permanenza, più fiducia e più probabilità di click.
            </p>

            <div class="inline-cta">
              <span>Approfondisci</span>
              <span>→</span>
            </div>
          </article>
        </div>

        <div class="grid">
          {posts.map((post, index) => (
            <article class={`card reveal delay-${(index % 4) + 1}`}>
              <div class="meta-line">{post.category} · {post.time}</div>
              <h3>{post.title}</h3>
              <p>{post.excerpt}</p>

              <div class="card-bottom">
                <span>Apri articolo</span>
                <span>→</span>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="principles container" id="principi">
        <div class="principles-grid">
          {principles.map((item, index) => (
            <article class={`principle reveal delay-${(index % 4) + 1}`}>
              <strong>{item.n}</strong>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="about" id="about">
        <div class="container about-grid">
          <div class="reveal">
            <div class="eyebrow">
              <span class="eyebrow-dot"></span>
              struttura editoriale premium
            </div>
            <h2>Design pulito, lettura semplice, attenzione guidata.</h2>
          </div>

          <div class="reveal delay-1">
            <p>
              Questa home non punta su effetti casuali o aggressivi. Punta su chiarezza,
              leggibilità, contrasto, ritmo e priorità. Il risultato è una pagina più credibile,
              più memorabile e più facile da esplorare. È questo che aumenta la probabilità
              che un visitatore resti, capisca e apra un contenuto.
            </p>
          </div>
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="container">
        © 2026 Blog Manuel. Struttura pensata per valorizzare contenuti, attenzione e leggibilità.
      </div>
    </footer>

    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("show");
              observer.unobserve(entry.target);
            }
          });
        },
        {
          threshold: 0.14,
          rootMargin: "0px 0px -40px 0px",
        }
      );

      document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));

      const progressBar = document.getElementById("progressBar");

      const updateProgress = () => {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
        progressBar.style.width = progress + "%";
      };

      updateProgress();
      window.addEventListener("scroll", updateProgress, { passive: true });
      window.addEventListener("resize", updateProgress);
    </script>
  </body>
</html>