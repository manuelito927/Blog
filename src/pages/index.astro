<!DOCTYPE html>
<html lang="it" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EUDAMONIA | Architettura della Mente Superiore</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --gold: #d4af37;
            --deep-black: #050505;
            --soft-white: #f4f4f4;
        }
        body {
            background-color: var(--deep-black);
            color: var(--soft-white);
            font-family: 'Inter', sans-serif;
            overflow-x: hidden;
        }
        .serif { font-family: 'Playfair Display', serif; }
        
        /* Glassmorphism avanzato */
        .glass {
            background: rgba(255, 255, 255, 0.02);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        /* Indicatore di lettura (Psicologia del completamento) */
        #progress-bar {
            height: 3px;
            background: linear-gradient(90deg, transparent, var(--gold));
            position: fixed;
            top: 0;
            left: 0;
            z-index: 100;
            transition: width 0.2s;
        }

        /* Animazione di entrata per i neuroni specchio */
        .fade-in {
            opacity: 0;
            transform: translateY(30px);
            transition: all 0.8s ease-out;
        }
        .fade-in.visible {
            opacity: 1;
            transform: translateY(0);
        }

        /* Pulsante con Effetto Scarsità */
        .cta-glow {
            box-shadow: 0 0 20px rgba(212, 175, 55, 0.2);
            transition: all 0.3s;
        }
        .cta-glow:hover {
            box-shadow: 0 0 40px rgba(212, 175, 55, 0.5);
            transform: scale(1.02);
        }
    </style>
</head>
<body>

    <div id="progress-bar" style="width: 0%"></div>

    <nav class="fixed w-full z-50 px-8 py-6 flex justify-between items-center mix-blend-difference">
        <div class="text-2xl font-bold tracking-tighter serif italic">Eudamonia.</div>
        <div class="hidden md:flex space-x-12 text-[10px] uppercase tracking-[0.3em] font-bold">
            <a href="#neuroscience" class="hover:text-[#d4af37] transition">Neuroscience</a>
            <a href="#philosophy" class="hover:text-[#d4af37] transition">Stoic Logic</a>
            <a href="#audit" class="hover:text-[#d4af37] transition">The Audit</a>
        </div>
        <div class="text-xs border border-white/20 px-4 py-2 rounded-full cursor-pointer hover:bg-white hover:text-black transition">
            Accesso Protocolli
        </div>
    </nav>

    <section class="relative min-h-screen flex items-center justify-center pt-20 overflow-hidden">
        <div class="absolute inset-0 z-0">
            <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[#050505] to-[#050505]"></div>
            <canvas id="heroCanvas" class="opacity-30"></canvas>
        </div>

        <div class="relative z-10 text-center max-w-5xl px-6">
            <span class="inline-block text-[#d4af37] tracking-[0.5em] uppercase text-[10px] mb-4 font-bold fade-in">Ingegneria del Potenziale Umano</span>
            <h1 class="text-6xl md:text-9xl serif italic leading-tight mb-8 fade-in">
                La Felicità è una <br> <span class="text-white not-italic font-extrabold tracking-tighter">Scienza Esatta.</span>
            </h1>
            <p class="text-gray-400 text-lg md:text-xl max-w-2xl mx-auto leading-relaxed mb-12 fade-in">
                Abbandona la crescita personale banale. Applichiamo i protocolli di <strong>Neuroplasticità</strong> e <strong>Stoicismo Operativo</strong> per riconfigurare il tuo Default Mode Network.
            </p>
            <div class="flex flex-col md:flex-row items-center justify-center gap-6 fade-in">
                <a href="#audit" class="cta-glow bg-[#d4af37] text-black font-black py-5 px-10 rounded-sm uppercase text-xs tracking-widest">Inizia il Protocollo</a>
                <span class="text-gray-600 text-xs italic tracking-widest">Basato su Seligman, 2011 (PERMA Theory)</span>
            </div>
        </div>
    </section>

    <section id="neuroscience" class="py-32 px-6">
        <div class="max-w-7xl mx-auto">
            <div class="grid md:grid-cols-2 gap-20 items-center">
                <div class="fade-in">
                    <h2 class="text-4xl md:text-5xl serif mb-8 italic italic">L'analisi dei Dati <br><span class="not-italic font-bold">non mente mai.</span></h2>
                    <p class="text-gray-400 leading-relaxed mb-8">
                        Secondo la <em>Broaden-and-Build Theory</em> (Fredrickson, 2004), le emozioni positive non sono semplici "piaceri", ma motori evolutivi che espandono il repertorio pensiero-azione. Questo sito non è un blog, è un laboratorio di <strong>Psicologia Economica</strong> applicata alla vita quotidiana.
                    </p>
                    <div class="space-y-6">
                        <div class="glass p-6 rounded-lg">
                            <h4 class="text-[#d4af37] font-bold text-sm mb-2 uppercase">Recettori Dopaminici</h4>
                            <p class="text-xs text-gray-500 italic">Ottimizzazione del circuito di ricompensa attraverso la gratitudine metodica.</p>
                        </div>
                    </div>
                </div>
                <div class="relative fade-in">
                    <canvas id="dataChart" class="max-w-full"></canvas>
                    <div class="absolute -bottom-10 -right-10 glass p-6 hidden md:block">
                        <span class="text-5xl font-black text-[#d4af37] block">+42%</span>
                        <span class="text-[10px] uppercase tracking-widest">Resilienza Cognitiva</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="audit" class="py-32 bg-white text-black">
        <div class="max-w-4xl mx-auto px-6 text-center">
            <h2 class="text-5xl serif italic font-bold mb-4">Self-Audit Cognitivo</h2>
            <p class="text-gray-600 mb-16 uppercase tracking-[0.2em] text-xs font-bold">Misura la tua distanza dall'Eudaimonia</p>
            
            <div id="quiz-container" class="text-left space-y-12">
                <div class="question-step" data-step="1">
                    <h3 class="text-2xl font-bold mb-6 italic">1. Qual è la tua capacità di "Flow" durante le task complesse?</h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <button onclick="nextStep(2)" class="border-2 border-black p-4 text-left hover:bg-black hover:text-white transition font-bold uppercase text-xs">A. Alta (Stato di immersione totale)</button>
                        <button onclick="nextStep(2)" class="border-2 border-black p-4 text-left hover:bg-black hover:text-white transition font-bold uppercase text-xs">B. Bassa (Distrazione costante)</button>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="philosophy" class="py-32 px-6 bg-[#0a0a0a]">
        <div class="max-w-7xl mx-auto text-center">
            <h2 class="text-6xl serif italic mb-16 fade-in">Oltre il Nihilismo.</h2>
            <div class="grid md:grid-cols-3 gap-8">
                <div class="glass p-10 text-left fade-in">
                    <span class="text-[#d4af37] text-4xl serif mb-6 block">01</span>
                    <h3 class="text-xl font-bold mb-4">Stoicismo Operativo</h3>
                    <p class="text-sm text-gray-500 leading-relaxed italic">"Non sono le cose a turbarci, ma il nostro giudizio su di esse." - Epitteto. Trasformiamo la teoria in algoritmi comportamentali.</p>
                </div>
                <div class="glass p-10 text-left border-t-2 border-[#d4af37] fade-in">
                    <span class="text-[#d4af37] text-4xl serif mb-6 block">02</span>
                    <h3 class="text-xl font-bold mb-4">Neuromarketing di Sé</h3>
                    <p class="text-sm text-gray-500 leading-relaxed italic">Vendi a te stesso la versione migliore della tua identità attraverso il reframing cognitivo costante.</p>
                </div>
                <div class="glass p-10 text-left fade-in">
                    <span class="text-[#d4af37] text-4xl serif mb-6 block">03</span>
                    <h3 class="text-xl font-bold mb-4">Bio-Ottimizzazione</h3>
                    <p class="text-sm text-gray-500 leading-relaxed italic">Il benessere non è spirituale. È chimico. Gestione del cortisolo e picchi di ossitocina basati sulla scienza.</p>
                </div>
            </div>
        </div>
    </section>

    <footer class="py-32 border-t border-white/10 px-6">
        <div class="max-w-4xl mx-auto text-center">
            <h2 class="text-4xl serif italic mb-8">Unisciti all'Elite Cognitiva.</h2>
            <p class="text-gray-500 mb-12 text-sm uppercase tracking-widest">Ricevi il "Protocollo Phronesis" (Solo 100 invii al mese per garantire l'esclusività)</p>
            
            <form class="flex flex-col md:flex-row gap-4 mb-16">
                <input type="email" placeholder="Indirizzo email criptato" class="bg-transparent border-b border-gray-700 py-4 px-6 w-full focus:outline-none focus:border-[#d4af37] transition text-sm">
                <button type="submit" class="bg-white text-black font-black px-12 py-4 uppercase text-[10px] tracking-widest hover:bg-[#d4af37] transition">Ottieni Accesso</button>
            </form>
            
            <div class="flex justify-center space-x-8 text-gray-600 text-[10px] uppercase font-bold tracking-widest">
                <span>© 2026 Eudamonia Lab</span>
                <a href="#">Etica della Mente</a>
                <a href="#">White Papers</a>
            </div>
        </div>
    </footer>

    <script>
        // 1. Progress Bar Logic
        window.onscroll = function() {
            let winScroll = document.body.scrollTop || document.documentElement.scrollTop;
            let height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
            let scrolled = (winScroll / height) * 100;
            document.getElementById("progress-bar").style.width = scrolled + "%";
            
            // Fade-in trigger
            document.querySelectorAll('.fade-in').forEach(el => {
                if (el.getBoundingClientRect().top < window.innerHeight * 0.8) {
                    el.classList.add('visible');
                }
            });
        };

        // 2. Background Animation (Visual Hook)
        const canvas = document.getElementById('heroCanvas');
        const ctx = canvas.getContext('2d');
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;

        let particles = [];
        for(let i=0; i<100; i++) {
            particles.push({
                x: Math.random() * canvas.width,
                y: Math.random() * canvas.height,
                size: Math.random() * 2,
                speedX: Math.random() * 0.5 - 0.25,
                speedY: Math.random() * 0.5 - 0.25
            });
        }

        function animate() {
            ctx.clearRect(0,0, canvas.width, canvas.height);
            ctx.fillStyle = '#d4af37';
            particles.forEach(p => {
                ctx.beginPath();
                ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
                ctx.fill();
                p.x += p.speedX;
                p.y += p.speedY;
                if(p.x > canvas.width) p.x = 0;
                if(p.y > canvas.height) p.y = 0;
            });
            requestAnimationFrame(animate);
        }
        animate();

        // 3. Chart Logic (Authority Building)
        const ctxChart = document.getElementById('dataChart').getContext('2d');
        new Chart(ctxChart, {
            type: 'line',
            data: {
                labels: ['Sett 1', 'Sett 2', 'Sett 3', 'Sett 4', 'Sett 5', 'Sett 6'],
                datasets: [{
                    label: 'Focus Cognitivo (Standard vs Protocollo E.)',
                    data: [12, 19, 15, 25, 32, 45],
                    borderColor: '#d4af37',
                    borderWidth: 3,
                    tension: 0.4,
                    pointBackgroundColor: '#fff'
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: { y: { display: false }, x: { grid: { display: false }, ticks: { color: '#555' } } }
            }
        });

        // 4. Interactive Quiz Logic (Engagement Loop)
        function nextStep(step) {
            const container = document.getElementById('quiz-container');
            if(step === 2) {
                container.innerHTML = `
                    <div class="fade-in visible">
                        <h3 class="text-2xl font-bold mb-6 italic animate-pulse">Analisi in corso...</h3>
                        <div class="w-full bg-gray-200 h-2 mb-8">
                            <div class="bg-black h-2" style="width: 70%; transition: width 2s"></div>
                        </div>
                        <p class="text-lg">Stiamo calcolando il tuo indice di <strong>Resilienza Filosofica</strong> basato sulla teoria di Seligman.</p>
                        <button onclick="showFinal()" class="mt-8 bg-black text-white px-10 py-4 font-bold uppercase text-xs">Vedi Risultato Esclusivo</button>
                    </div>
                `;
            }
        }

        function showFinal() {
            const container = document.getElementById('quiz-container');
            container.innerHTML = `
                <div class="fade-in visible text-center p-10 border-4 border-black">
                    <h3 class="text-4xl font-bold mb-4">Livello: Architetto Latente</h3>
                    <p class="mb-6">Il tuo cervello mostra una predisposizione naturale alla <strong>Neuroplasticità</strong>, ma è attualmente bloccato da bias cognitivi di base. </p>
                    <a href="#philosophy" class="inline-block bg-[#d4af37] text-black px-8 py-3 font-bold uppercase text-xs">Sblocca il Potenziale</a>
                </div>
            `;
        }
    </script>
</body>
</html>