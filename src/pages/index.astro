---
// ARCHITETTURA DATI: RIGORE E AUTORITÀ
const metadata = {
  title: "MANUEL ARCHIVE | Neuroscienze e Comportamento",
  description: "Ricerca indipendente su performance, biologia del carattere e modelli mentali."
};

const featured = {
  label: "RESEARCH_PAPER #01",
  title: "La Biologia della Resilienza: Meccanismi di Regolazione Top-Down",
  excerpt: "Perché alcuni sistemi nervosi collassano sotto stress mentre altri si potenziano? Analisi dei circuiti della corteccia prefrontale.",
  readTime: "12 MIN",
  citations: 18,
  level: "AVANZATO"
};

const articles = [
  {
    category: "PSICOLOGIA COGNITIVA",
    title: "Bias di Conferma e Dissonanza: L'architettura dell'inganno",
    time: "8 MIN",
    preview: "Come il cervello filtra la realtà per proteggere l'identità a discapito della verità."
  },
  {
    category: "NEUROCHIMICA",
    title: "Dopamina e Sforzo: Il costo biologico della disciplina",
    time: "10 MIN",
    preview: "Analisi dei recettori D2 e della loro influenza sulla perseveranza nel lungo periodo."
  },
  {
    category: "FILOSOFIA",
    title: "Logos e Prassi: La razionalità applicata al caos",
    time: "7 MIN",
    preview: "Dall'antico stoicismo alle moderne terapie comportamentali: un ponte necessario."
  }
];
---

<html lang="it">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
    <title>{metadata.title}</title>
    <style>
        :root {
            /* Palette Scientifica (Oxford-Tech Style) */
            --bg: #08090a;
            --surface: #111216;
            --surface-alt: #1a1c22;
            --accent: #7d9bbd; /* Blu Ardesia: Calma e Autorità */
            --text-p: #e2e8f0; /* Bianco sporco per non affaticare gli occhi */
            --text-s: #94a3b8;
            --border: rgba(255, 255, 255, 0.06);
            --font-serif: 'Charter', 'Bitstream Charter', 'Sitka Text', Cambria, serif;
            --font-sans: 'Inter', system-ui, -apple-system, sans-serif;
        }

        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        
        body {
            background-color: var(--bg);
            color: var(--text-p);
            font-family: var(--font-sans);
            margin: 0;
            line-height: 1.6;
            overflow-x: hidden;
            text-rendering: optimizeLegibility;
        }

        /* BARRA DI PROGRESSO (Dopamine Loop) */
        #progress-bar {
            position: fixed; top: 0; left: 0; height: 3px;
            background: linear-gradient(90deg, var(--accent), #fff);
            z-index: 9999; width: 0%;
        }

        .container { 
            width: min(1200px, 100% - 40px); 
            margin: 0 auto; 
        }

        /* HEADER: Mobile Optimized */
        nav {
            padding: 1.5rem 0;
            display: flex; justify-content: space-between; align-items: center;
            border-bottom: 1px solid var(--border);
        }
        .logo { 
            font-weight: 800; font-size: 0.85rem; letter-spacing: 2px; 
            text-transform: uppercase; color: var(--accent);
        }
        .nav-meta { font-size: 0.7rem; color: var(--text-s); font-weight: 600; }

        /* HERO: The Hook */
        .hero { padding: 4rem 0 3rem; }
        .hero-tag { 
            font-size: 0.7rem; font-weight: 700; color: var(--accent); 
            text-transform: uppercase; letter-spacing: 2px; margin-bottom: 1rem; display: block;
        }
        h1 { 
            font-family: var(--font-serif);
            font-size: clamp(2.2rem, 8vw, 4rem); 
            line-height: 1.1; font-weight: 400; margin: 0 0 1.5rem 0;
            letter-spacing: -0.02em;
        }
        .hero-sub { 
            font-size: 1.1rem; color: var(--text-s); max-width: 600px; 
            line-height: 1.7; border-left: 1px solid var(--accent); padding-left: 20px;
        }

        /* GRID SYSTEM (Responsive) */
        .content-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 2rem;
            margin: 2rem 0 5rem;
        }

        @media (min-width: 1024px) {
            .content-grid { grid-template-columns: 2fr 1fr; gap: 4rem; }
        }

        /* FEATURED CARD */
        .featured-card {
            background: var(--surface);
            padding: 2.5rem;
            border-radius: 4px;
            border: 1px solid var(--border);
            text-decoration: none; color: inherit;
            transition: transform 0.3s ease, border-color 0.3s ease;
        }
        .featured-card:hover { border-color: var(--accent); transform: translateY(-4px); }
        .card-meta { display: flex; gap: 1rem; font-size: 0.65rem; color: var(--accent); font-weight: 700; margin-bottom: 1rem; }

        /* SECONDARY ARTICLES */
        .article-list { display: grid; gap: 2rem; }
        .article-item { 
            text-decoration: none; color: inherit;
            padding-bottom: 1.5rem; border-bottom: 1px solid var(--border);
            display: block; transition: 0.3s;
        }
        .article-item:hover { opacity: 0.7; }
        .article-item h3 { font-family: var(--font-serif); font-size: 1.4rem; font-weight: 400; margin: 0.5rem 0; }
        .article-item p { color: var(--text-s); font-size: 0.9rem; margin: 0; }

        /* SIDEBAR (Authority Tools) */
        .sidebar { display: grid; gap: 2rem; align-content: start; }
        .sidebar-box { 
            background: var(--surface-alt); padding: 1.5rem; border-radius: 4px; 
            border: 1px solid var(--border);
        }
        .sidebar-box h4 { 
            font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; 
            color: var(--accent); margin-top: 0;
        }
        .sidebar-text { font-size: 0.85rem; color: var(--text-s); margin: 0; }

        /* FOOTER */
        footer { 
            padding: 4rem 0; border-top: 1px solid var(--border); 
            text-align: center; color: var(--text-s); font-size: 0.75rem; 
        }

        /* ANIMATIONS */
        .reveal { opacity: 0; transform: translateY(20px); transition: 0.8s ease-out; }
        .reveal.active { opacity: 1; transform: translateY(0); }
    </style>
</head>
<body>
    <div id="progress-bar"></div>

    <div class="container">
        <nav>
            <div class="logo">MANUEL // ARCHIVE</div>
            <div class="nav-meta">EST. 2026 // OPEN ACCESS</div>
        </nav>

        <header class="hero reveal">
            <span class="hero-tag">Laboratorio di Ricerca Comportamentale</span>
            <h1>Analisi tecnica della mente e dei sistemi di performance.</h1>
            <p class="hero-sub">
                Benvenuto. Qui non troverai crescita personale generica, ma analisi dei processi bio-psicologici che governano l'essere umano.
            </p>
        </header>

        <main class="content-grid">
            <section class="reveal">
                <a href="#" class="featured-card">
                    <div class="card-meta">
                        <span>{featured.label}</span>
                        <span>{featured.readTime}</span>
                        <span>{featured.citations} CITAZIONI</span>
                    </div>
                    <h2 style="font-family: var(--font-serif); font-size: 2rem; margin: 0 0 1rem 0; font-weight: 400;">{featured.title}</h2>
                    <p style="color: var(--text-s); margin-bottom: 2rem;">{featured.excerpt}</p>
                    <span style="font-size: 0.8rem; font-weight: 700; border-bottom: 1px solid var(--accent);">LEGGI IL PAPER INTEGRALE</span>
                </a>

                <div style="margin-top: 4rem;">
                    <h2 style="font-size: 0.8rem; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 2rem; color: var(--text-s);">Ultimi Aggiornamenti</h2>
                    <div class="article-list">
                        {articles.map(art => (
                            <a href="#" class="article-item">
                                <div class="card-meta" style="margin-bottom: 0.2rem;">
                                    <span>{art.category}</span>
                                    <span>{art.time}</span>
                                </div>
                                <h3>{art.title}</h3>
                                <p>{art.preview}</p>
                            </a>
                        ))}
                    </div>
                </div>
            </section>

            <aside class="sidebar">
                <div class="sidebar-box reveal">
                    <h4>Metodologia</h4>
                    <p class="sidebar-text">
                        Ogni articolo segue rigorosi criteri di peer-review interna. Citiamo solo fonti primarie da riviste di settore (Nature, Science, PubMed).
                    </p>
                </div>

                <div class="sidebar-box reveal" style="border-left: 3px solid var(--accent);">
                    <h4>Livello di Analisi</h4>
                    <div style="display: flex; gap: 5px; margin-top: 10px;">
                        <span style="width: 20%; height: 4px; background: var(--accent);"></span>
                        <span style="width: 20%; height: 4px; background: var(--accent);"></span>
                        <span style="width: 20%; height: 4px; background: var(--accent);"></span>
                        <span style="width: 20%; height: 4px; background: var(--border);"></span>
                        <span style="width: 20%; height: 4px; background: var(--border);"></span>
                    </div>
                    <p class="sidebar-text" style="margin-top: 10px;">Complessità media attuale: <strong>72% (Technical)</strong></p>
                </div>

                <div class="sidebar-box reveal">
                    <h4>Status dell'Archivio</h4>
                    <p class="sidebar-text">
                        Aggiornato in tempo reale. Nuove analisi caricate ogni 72 ore.
                    </p>
                </div>
            </aside>
        </main>

        <footer>
            <p>© 2026 MANUEL ARCHIVE. NESSUNA IA È STATA UTILIZZATA PER LA VALIDAZIONE SCIENTIFICA DELLE TESI.</p>
        </footer>
    </div>

    <script>
        // Progress Bar
        window.onscroll = () => {
            const scroll = document.documentElement.scrollTop;
            const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
            document.getElementById("progress-bar").style.width = (scroll / height) * 100 + "%";
        };

        // Smooth Reveal
        const observer = new IntersectionObserver(entries => {
            entries.forEach(e => { if(e.isIntersecting) e.target.classList.add('active'); });
        }, { threshold: 0.1 });
        document.querySelectorAll('.reveal').forEach(r => observer.observe(r));
    </script>
</body>
</html>