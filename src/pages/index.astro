---
const metadata = {
  title: "Manuel | Mente, Presenza, Disciplina",
  description: "Un blog editoriale su psicologia, filosofia e performance interiore. Idee chiare, riflessioni profonde e strumenti per capire meglio la mente."
};

const featuredPost = {
  id: 1,
  category: "Mente",
  title: "La qualità dei tuoi pensieri cambia il modo in cui vivi le giornate",
  excerpt: "Non è solo ciò che accade a determinare come stai, ma il filtro mentale con cui leggi ciò che ti accade. Capire questo cambia molte cose.",
  date: "14 Marzo 2026",
  readingTime: "8 min",
  citations: 6
};

const recentArticles = [
  {
    category: "Psicologia",
    title: "Perché la mente nota più facilmente ciò che manca",
    excerpt: "Un meccanismo antico, ancora attivo, che spesso ti porta a vedere prima il rischio e solo dopo la possibilità.",
    time: "6 min",
    level: "Essenziale"
  },
  {
    category: "Filosofia",
    title: "Accettare non significa arrendersi",
    excerpt: "C’è una differenza sottile ma decisiva tra rinunciare e smettere di combattere ciò che non puoi controllare.",
    time: "7 min",
    level: "Intermedio"
  },
  {
    category: "Disciplina",
    title: "La forza mentale si costruisce quando la motivazione cala",
    excerpt: "La costanza non nasce dall’entusiasmo. Nasce dal rapporto che impari ad avere con la fatica e con il dubbio.",
    time: "6 min",
    level: "Pratico"
  }
];

const methodology = [
  { title: "Chiarezza", desc: "Ogni contenuto è scritto per rendere comprensibili idee complesse senza semplificarle in modo superficiale." },
  { title: "Profondità", desc: "Psicologia, filosofia e performance vengono trattate come strumenti per leggere meglio la vita reale." },
  { title: "Applicazione", desc: "Ogni riflessione cerca un punto concreto: qualcosa che puoi osservare, provare o portare con te." }
];
---

<html lang="it">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{metadata.title}</title>
    <meta name="description" content={metadata.description} />
    <style>
        :root {
            --bg: #0b0c10;
            --surface: #141821;
            --accent: #7f97bd;
            --text-primary: #edf2f7;
            --text-secondary: #9aa8bb;
            --border: rgba(255, 255, 255, 0.08);
            --font-serif: 'Georgia', serif;
            --font-sans: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            --radius: 8px;
        }

        * {
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
            -webkit-text-size-adjust: 100%;
        }

        body {
            background-color: var(--bg);
            color: var(--text-primary);
            font-family: var(--font-sans);
            margin: 0;
            line-height: 1.72;
            -webkit-font-smoothing: antialiased;
            text-rendering: optimizeLegibility;
        }

        a {
            color: inherit;
        }

        .progress-bar {
            position: fixed;
            top: 0;
            left: 0;
            height: 2px;
            background: var(--accent);
            z-index: 1000;
            width: 0%;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 40px;
        }

        nav {
            padding: 1.4rem 0;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 20px;
        }

        .logo {
            font-weight: 700;
            letter-spacing: 1px;
            font-size: 0.9rem;
            text-transform: uppercase;
            white-space: nowrap;
        }

        .logo span {
            color: var(--accent);
        }

        .nav-links {
            display: flex;
            gap: 2rem;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            flex-wrap: wrap;
            justify-content: flex-end;
        }

        .nav-links a {
            text-decoration: none;
            color: var(--text-secondary);
            transition: color 0.3s ease;
        }

        .nav-links a:hover {
            color: var(--accent);
        }

        .hero {
            padding: 110px 0 72px;
            border-bottom: 1px solid var(--border);
        }

        .hero-label {
            color: var(--accent);
            font-size: 0.8rem;
            font-weight: 600;
            text-transform: uppercase;
            margin-bottom: 1rem;
            display: block;
            letter-spacing: 1px;
        }

        h1 {
            font-family: var(--font-serif);
            font-size: clamp(2.2rem, 5vw, 3.7rem);
            line-height: 1.05;
            margin: 0 0 1.4rem;
            font-weight: 400;
            max-width: 13ch;
        }

        .hero-desc {
            max-width: 760px;
            color: var(--text-secondary);
            font-size: 1.08rem;
            line-height: 1.82;
            margin: 0;
        }

        .hero-note {
            margin-top: 1.5rem;
            color: var(--text-secondary);
            font-size: 0.88rem;
            letter-spacing: 0.02em;
        }

        .main-grid {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 60px;
            margin: 60px 0;
        }

        .featured-card {
            text-decoration: none;
            color: inherit;
            display: block;
            margin-bottom: 60px;
        }

        .featured-card:hover h2 {
            text-decoration: underline;
            color: var(--accent);
        }

        .meta {
            font-size: 0.75rem;
            color: var(--text-secondary);
            margin-bottom: 1rem;
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
            line-height: 1.6;
        }

        .meta span {
            border-left: 1px solid var(--border);
            padding-left: 15px;
        }

        .meta span:first-child {
            border: none;
            padding: 0;
        }

        h2 {
            font-family: var(--font-serif);
            font-size: 2.25rem;
            line-height: 1.12;
            margin: 0 0 1.15rem;
            font-weight: 400;
            max-width: 18ch;
        }

        .excerpt {
            color: var(--text-secondary);
            font-size: 1rem;
            line-height: 1.82;
            margin-bottom: 1.5rem;
            max-width: 62ch;
        }

        .featured-cta {
            font-weight: 600;
            font-size: 0.82rem;
            color: var(--accent);
            letter-spacing: 0.5px;
        }

        .sidebar-section {
            margin-bottom: 28px;
            padding: 28px;
            background: var(--surface);
            border-radius: var(--radius);
            border: 1px solid var(--border);
        }

        .sidebar-section h3 {
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-top: 0;
            margin-bottom: 1.1rem;
            color: var(--accent);
        }

        .sidebar-item {
            margin-bottom: 18px;
            font-size: 0.9rem;
        }

        .sidebar-item:last-child {
            margin-bottom: 0;
        }

        .sidebar-item strong {
            display: block;
            color: var(--text-primary);
            margin-bottom: 6px;
        }

        .sidebar-item p {
            margin: 0;
            color: var(--text-secondary);
            font-size: 0.88rem;
            line-height: 1.68;
        }

        .article-list {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 40px;
        }

        .small-card {
            text-decoration: none;
            color: inherit;
            display: block;
        }

        .small-card h4 {
            font-family: var(--font-serif);
            font-size: 1.35rem;
            line-height: 1.22;
            margin: 10px 0 12px;
            font-weight: 400;
            transition: color 0.3s ease;
        }

        .small-card:hover h4 {
            color: var(--accent);
        }

        .small-card .excerpt {
            font-size: 0.92rem;
            margin-bottom: 0;
        }

        footer {
            padding: 80px 0 40px;
            border-top: 1px solid var(--border);
            color: var(--text-secondary);
            font-size: 0.8rem;
        }

        .footer-inner {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 20px;
        }

        .footer-links {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
        }

        .footer-links a {
            color: inherit;
            text-decoration: none;
        }

        .reveal {
            opacity: 0;
            transform: translateY(20px);
            transition: 0.8s all ease;
        }

        .reveal.show {
            opacity: 1;
            transform: translateY(0);
        }

        @media (max-width: 900px) {
            .container {
                padding: 0 24px;
            }

            nav {
                padding: 1.1rem 0;
                align-items: flex-start;
                flex-direction: column;
            }

            .nav-links {
                gap: 1rem 1.2rem;
                font-size: 0.74rem;
                justify-content: flex-start;
            }

            .hero {
                padding: 72px 0 52px;
            }

            .hero-desc {
                font-size: 1rem;
            }

            .main-grid {
                grid-template-columns: 1fr;
                gap: 34px;
                margin: 42px 0;
            }

            .article-list {
                grid-template-columns: 1fr;
                gap: 28px;
            }

            h2 {
                font-size: 1.8rem;
                max-width: 100%;
            }

            .sidebar-section {
                padding: 22px;
            }

            footer {
                padding: 56px 0 32px;
            }
        }

        @media (max-width: 640px) {
            .container {
                padding: 0 18px;
            }

            .logo {
                font-size: 0.82rem;
            }

            .nav-links {
                width: 100%;
                gap: 0.8rem 1rem;
                font-size: 0.7rem;
                letter-spacing: 0.8px;
            }

            .hero {
                padding: 54px 0 40px;
            }

            .hero-label {
                font-size: 0.72rem;
                margin-bottom: 0.85rem;
            }

            h1 {
                font-size: 2.1rem;
                line-height: 1.08;
                margin-bottom: 1.1rem;
                max-width: 100%;
            }

            .hero-desc {
                font-size: 0.98rem;
                line-height: 1.76;
            }

            .hero-note {
                font-size: 0.8rem;
            }

            .main-grid {
                margin: 30px 0;
                gap: 24px;
            }

            .featured-card {
                margin-bottom: 36px;
            }

            .meta {
                gap: 8px 12px;
                font-size: 0.7rem;
            }

            .meta span {
                padding-left: 10px;
            }

            h2 {
                font-size: 1.55rem;
                line-height: 1.18;
                margin-bottom: 1rem;
            }

            .excerpt {
                font-size: 0.96rem;
                line-height: 1.74;
                margin-bottom: 1.2rem;
            }

            .featured-cta {
                font-size: 0.76rem;
            }

            .article-list {
                gap: 22px;
            }

            .small-card {
                padding-bottom: 20px;
                border-bottom: 1px solid var(--border);
            }

            .small-card:last-child {
                border-bottom: none;
                padding-bottom: 0;
            }

            .small-card h4 {
                font-size: 1.18rem;
                margin: 8px 0 10px;
            }

            .small-card .excerpt {
                font-size: 0.9rem;
            }

            .sidebar-section {
                padding: 18px;
                border-radius: 6px;
            }

            .sidebar-section h3 {
                font-size: 0.72rem;
                letter-spacing: 1.6px;
            }

            .sidebar-item strong {
                font-size: 0.95rem;
            }

            .sidebar-item p {
                font-size: 0.84rem;
            }

            footer {
                padding: 44px 0 28px;
                font-size: 0.76rem;
            }

            .footer-inner {
                align-items: flex-start;
                flex-direction: column;
            }

            .footer-links {
                gap: 14px;
            }
        }
    </style>
</head>
<body>
    <div class="progress-bar" id="pb"></div>

    <div class="container">
        <nav>
            <div class="logo">Manuel <span>/</span> Archive</div>
            <div class="nav-links">
                <a href="#articles">Articoli</a>
                <a href="#method">Approccio</a>
                <a href="#about">Informazioni</a>
            </div>
        </nav>

        <header class="hero reveal">
            <span class="hero-label">Riflessioni, psicologia, presenza</span>
            <h1>Un luogo per capire meglio la mente e il modo in cui orienta la tua vita.</h1>
            <p class="hero-desc">
                Psicologia, filosofia e disciplina interiore si incontrano qui in una forma più chiara,
                più leggibile e più vicina alla vita reale. Non per semplificare tutto, ma per aiutarti
                a vedere con più precisione ciò che spesso resta confuso.
            </p>
            <div class="hero-note">
                Idee da leggere con calma. Strumenti da portare fuori dalla pagina.
            </div>
        </header>

        <main class="main-grid">
            <section id="articles">
                <a href="#" class="featured-card reveal">
                    <div class="meta">
                        <span>{featuredPost.category}</span>
                        <span>{featuredPost.date}</span>
                        <span>{featuredPost.readingTime} lettura</span>
                        <span>{featuredPost.citations} riferimenti</span>
                    </div>
                    <h2>{featuredPost.title}</h2>
                    <p class="excerpt">{featuredPost.excerpt}</p>
                    <div class="featured-cta">LEGGI L'ARTICOLO →</div>
                </a>

                <div class="article-list">
                    {recentArticles.map(post => (
                        <a href="#" class="small-card reveal">
                            <div class="meta">
                                <span>{post.category}</span>
                                <span>{post.time}</span>
                            </div>
                            <h4>{post.title}</h4>
                            <p class="excerpt">{post.excerpt}</p>
                        </a>
                    ))}
                </div>
            </section>

            <aside id="method">
                <div class="sidebar-section reveal">
                    <h3>Approccio</h3>
                    {methodology.map(m => (
                        <div class="sidebar-item">
                            <strong>{m.title}</strong>
                            <p>{m.desc}</p>
                        </div>
                    ))}
                </div>

                <div class="sidebar-section reveal">
                    <h3>Come leggere</h3>
                    <p style="font-size: 0.85rem; color: var(--text-secondary); line-height: 1.72; margin: 0;">
                        Alcuni articoli sono più immediati, altri più densi. L’idea non è correre, ma trovare
                        il ritmo giusto per capire davvero.
                    </p>
                </div>
            </aside>
        </main>

        <footer id="about">
            <div class="footer-inner">
                <div>© 2026 Manuel Archive. Uno spazio editoriale dedicato a mente, presenza e disciplina interiore.</div>
                <div class="footer-links">
                    <a href="#">RSS Feed</a>
                    <a href="#">Privacy Policy</a>
                </div>
            </div>
        </footer>
    </div>

    <script>
        window.onscroll = () => {
            const scroll = document.documentElement.scrollTop;
            const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
            document.getElementById("pb").style.width = (scroll / height) * 100 + "%";
        };

        const obs = new IntersectionObserver(entries => {
            entries.forEach(e => {
                if (e.isIntersecting) e.target.classList.add('show');
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('.reveal').forEach(r => obs.observe(r));
    </script>
</body>
</html>